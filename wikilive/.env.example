# ====================================================================
# WikiLive — Environment Variables Template
# Copy this file to .env and fill in ALL values before starting.
# NEVER commit .env to version control.
# ====================================================================

# База данных — ОБЯЗАТЕЛЬНО задайте надёжный пароль, но пока можно рандомный
POSTGRES_USER=wikilive
POSTGRES_PASSWORD=          
POSTGRES_DB=wikilive
DATABASE_URL=postgresql://wikilive:REPLACE_ME@postgres:5432/wikilive

# MWS Tables интеграция (опционально, без токенов таблицы не работают)
# Получить токен: https://tables.mws.ru → Настройки → API ключи
MWS_TABLES_BASE_URL=https://tables.mws.ru
MWS_TABLES_TOKEN=
MWS_TABLES_SPACE_ID=

# MWS GPT интеграция (опционально, без ключа AI не работает)
# Получить ключ: https://api.gpt.mws.ru → Настройки → API ключи
MWS_GPT_API_URL=https://api.gpt.mws.ru/v1/chat/completions
MWS_GPT_API_KEY=
AI_CONTEXT_MODE=disabled

# Порты бэкенда (дефолтные значения)
PORT=3001
WS_PORT=3002

# JWT для cookie-сессии — ОБЯЗАТЕЛЬНО задайте длинную случайную строку (≥16 символов)
# Сервер откажется стартовать с placeholder-значениями или короткими секретами.
COOKIE_SECRET=

# CORS разрешённый origin (для локальной разработки http://localhost:3000)
ALLOWED_ORIGIN=http://localhost:3000
