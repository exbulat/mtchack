# Скопируйте этот файл в .env и заполните значения ниже.

# Обязательные значения
POSTGRES_USER=wikilive
POSTGRES_PASSWORD=your_postgres_password
POSTGRES_DB=wikilive
COOKIE_SECRET=your_long_random_secret

# Нужен только если запускаете backend не через docker compose
DATABASE_URL=postgresql://wikilive:your_postgres_password@postgres:5432/wikilive

# Порты
PORT=3001
WS_PORT=3002
ALLOWED_ORIGIN=http://localhost:3000

# Опционально: интеграция с MWS Tables
MWS_TABLES_BASE_URL=https://tables.mws.ru
MWS_TABLES_TOKEN=
MWS_TABLES_SPACE_ID=

# Опционально: AI
MWS_GPT_API_URL=https://api.gpt.mws.ru/v1/chat/completions
MWS_GPT_API_KEY=
AI_CONTEXT_MODE=disabled
