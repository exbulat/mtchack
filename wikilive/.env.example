# База данных (дефолтные значения в docker-compose.yml, этот файл не обязателен)
DATABASE_URL=postgresql://wikilive:YOUR_SECURE_PASSWORD@postgres:5432/wikilive

# MWS Tables интеграция (опционально, без токенов таблицы не работают)
# Получить токен: https://tables.mws.ru → Настройки → API ключи
MWS_TABLES_BASE_URL=https://tables.mws.ru
MWS_TABLES_TOKEN=usk_YOUR_API_TOKEN_HERE
MWS_TABLES_SPACE_ID=YOUR_SPACE_ID_HERE

# MWS GPT интеграция (опционально, без ключа AI не работает)
# Получить ключ: https://api.gpt.mws.ru → Настройки → API ключи
MWS_GPT_API_URL=https://api.gpt.mws.ru/v1/chat/completions
MWS_GPT_API_KEY=sk_YOUR_SECURE_KEY_HERE

# Порты бэкенда (дефолтные значения)
PORT=3001
WS_PORT=3002

# JWT для cookie-сессии (в проде задайте длинную случайную строку)
COOKIE_SECRET=change-me-in-production-use-long-random-string

# CORS разрешённый origin (для локальной разработки http://localhost:3000)
ALLOWED_ORIGIN=http://localhost:3000
