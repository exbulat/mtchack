generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(uuid())
  email        String   @unique
  passwordHash String
  name         String
  avatarColor  String   @default("#6366f1")
  createdAt    DateTime @default(now())

  pages Page[]
  spaces       Space[]       @relation("SpaceOwner")
  spaceMembers SpaceMember[] @relation("SpaceMemberUser")
  ownedFiles   File[]        @relation("FileOwner")
}

model Page {
  id        String    @id @default(uuid())
  title     String    @default("Без названия")
  content   Json      @default("{\"type\":\"doc\",\"content\":[{\"type\":\"paragraph\"}]}")
  icon      String    @default("")
  ownerId   String?
  spaceId   String?   @map("space_id")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  deletedAt DateTime? @map("deleted_at")

  owner         User?          @relation(fields: [ownerId], references: [id], onDelete: SetNull)
  space         Space?         @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  outgoingLinks PageLink[]     @relation("source")
  incomingLinks PageLink[]     @relation("target")
  revisions     PageRevision[]
  comments      Comment[]
}

model PageLink {
  id       String @id @default(uuid())
  sourceId String
  targetId String

  source Page @relation("source", fields: [sourceId], references: [id], onDelete: Cascade)
  target Page @relation("target", fields: [targetId], references: [id], onDelete: Cascade)

  @@unique([sourceId, targetId])
}

model PageRevision {
  id        String   @id @default(uuid())
  pageId    String
  content   Json
  createdAt DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model Comment {
  id        String   @id @default(uuid())
  pageId    String
  blockId   String   @default("")
  text      String
  authorId  String   @default("anonymous")
  resolved  Boolean  @default(false)
  createdAt DateTime @default(now())

  page Page @relation(fields: [pageId], references: [id], onDelete: Cascade)
}

model Space {
  id        String       @id @default(uuid())
  name      String
  icon      String?
  color     String       @default("#7C3AED")
  ownerId   String       @map("owner_id")
  owner     User         @relation("SpaceOwner", fields: [ownerId], references: [id], onDelete: Cascade)
  createdAt DateTime     @default(now()) @map("created_at")
  updatedAt DateTime     @updatedAt
  deletedAt DateTime?    @map("deleted_at")
  members   SpaceMember[]
  files     File[]
  pages     Page[]

  @@map("spaces")
}

model SpaceMember {
  id        String     @id @default(uuid())
  spaceId   String
  userId    String
  role      SpaceRole  @default(READER)
  invitedAt DateTime   @default(now())

  space Space @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  user  User  @relation("SpaceMemberUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([spaceId, userId], name: "space_user_idx")
}

model File {
  id        String     @id @default(uuid())
  spaceId   String
  title     String     @default("Untitled")
  content   Json       @default("{}")
  ownerId   String?
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
  space     Space      @relation(fields: [spaceId], references: [id], onDelete: Cascade)
  owner     User?      @relation("FileOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  views     View[]
}

model View {
  id     String   @id @default(uuid())
  fileId String
  type   ViewType
  name   String?
  config Json?
  file   File     @relation(fields: [fileId], references: [id], onDelete: Cascade)
}

enum SpaceRole {
  OWNER
  ADMIN
  EDITOR
  READER
}

enum ViewType {
  TABLE
  KANBAN
  CALENDAR
  GANTT
}
